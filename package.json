{
  "name": "nano-prompt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/generate-prompts.mjs && next dev",
    "build": "node scripts/generate-prompts.mjs && next build",
    "generate": "node scripts/generate-prompts.mjs",
    "fetch": "node scripts/fetch-sources.mjs",
    "update": "node scripts/fetch-sources.mjs && node scripts/generate-prompts.mjs",
    "d1:sync": "node scripts/d1-sync.mjs",
    "d1:migrate": "wrangler d1 migrations apply nano-prompts --remote",
    "d1:migrate:local": "wrangler d1 migrations apply nano-prompts --local",
    "cf:d1:create": "wrangler d1 create nano-prompts",
    "cf:migrate:local": "wrangler d1 migrations apply nano-prompts --local",
    "cf:migrate:remote": "wrangler d1 migrations apply nano-prompts --remote",
    "d1:apply": "node scripts/generate-prompts.mjs && node scripts/d1-sync.mjs --apply",
    "worker:deploy": "wrangler deploy",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-masonry-css": "^1.0.16"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
